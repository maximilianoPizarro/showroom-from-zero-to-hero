<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="https://demo.redhat.com" target="_blank" style="margin-left: 2.5%; width: 224px">
        <img src="{{{uiRootPath}}}/img/logo-demo-platform.svg" alt="Demo Platform" style="height: 40px; width: auto;">
      </a>
      <a class="navbar-item site-title" target="__blank" style="color: #fff !important;" href="{{{or site.url (or siteRootUrl siteRootPath)}}}">{{site.title}}</a>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <div class="navbar-item cluster-domain-form">
          <input type="text" id="cluster-domain-input" placeholder="Cluster domain (e.g. apps.cluster-xxx.region.openshiftapps.com)" title="Enter your cluster domain to auto-complete links">
          <button type="button" id="cluster-domain-save" class="cluster-domain-btn">Save</button>
          <button type="button" id="cluster-domain-clear" class="cluster-domain-btn cluster-domain-btn-clear">Clear</button>
        </div>
        {{#if page.attributes.links}}
        <div class="navbar-item navbar-item-right-dropdown has-dropdown is-hoverable">
          <a class="navbar-link" href="#">Links</a>
          <div class="navbar-dropdown navbar-dropdown-right">
            <a class="navbar-item navbar-item-right-content" href="{{page.attributes.rhoai_dashboard_url}}" target="_blank">OpenShift AI Dashboard</a>
            <a class="navbar-item navbar-item-right-content" href="{{page.attributes.openshift_cluster_console_url}}" target="_blank">OpenShift Console</a>
          </div>
        </div>
        {{/if}}
        {{#if page.attributes.user}}
        <div class="navbar-item">You are {{page.attributes.user}}</div>
        {{/if}}
      </div>
    </div>
  </nav>
</header>
