<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="https://demo.redhat.com" target="_blank" style="margin-left: 2.5%; width: 224px">
        <img src="{{{uiRootPath}}}/img/logo-demo-platform.svg" alt="Demo Platform" style="height: 40px; width: auto;">
      </a>
      <a class="navbar-item site-title" target="__blank" style="color: #fff !important;" href="{{{or site.url (or siteRootUrl siteRootPath)}}}">{{site.title}}</a>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <div class="navbar-item" style="gap:8px;flex-wrap:wrap;align-items:center;">
          <span id="user-badge" style="display:none;background:#292929;color:#fff;padding:4px 12px;border-radius:16px;font-size:0.85rem;border:1px solid #444;">
            <i class="fa fa-user" style="margin-right:4px;"></i>
            <span id="user-badge-name"></span>
          </span>
          <div id="vars-edit-panel" style="display:none;gap:8px;flex-wrap:wrap;align-items:center;">
            <label style="color:#fff;font-size:0.85rem;">User:</label>
            <input type="text" id="user-name-input" style="width:80px;padding:2px 6px;border-radius:4px;border:1px solid #ccc;font-size:0.85rem;" placeholder="user1">
            <button type="button" id="vars-save" style="background:#0066cc;color:#fff;border:none;padding:3px 10px;border-radius:4px;cursor:pointer;font-size:0.8rem;">Save</button>
            <button type="button" id="vars-cancel-edit" style="background:#6a6e73;color:#fff;border:none;padding:3px 10px;border-radius:4px;cursor:pointer;font-size:0.8rem;">Cancel</button>
          </div>
          <button type="button" id="vars-edit-btn" title="Change user" style="display:none;background:transparent;color:#ccc;border:1px solid #555;padding:2px 8px;border-radius:4px;cursor:pointer;font-size:0.75rem;">
            <i class="fa fa-pencil"></i>
          </button>
          <span style="color:#555;margin:0 2px;">|</span>
          <div id="lang-switcher" style="display:inline-flex;gap:2px;">
            <button type="button" class="lang-btn" data-lang="es" style="background:#EE0000;color:#fff;border:none;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:0.8rem;font-weight:bold;">ES</button>
            <button type="button" class="lang-btn" data-lang="en" style="background:#3c3c3c;color:#ccc;border:1px solid #555;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:0.8rem;">EN</button>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>
<script>
(function() {
  function getSearchParams() {
    var params = new URLSearchParams(window.location.search);
    try {
      if (window.parent && window.parent !== window) {
        var pp = new URLSearchParams(window.parent.location.search);
        pp.forEach(function(val, key) { if (!params.has(key)) params.set(key, val); });
      }
    } catch(e) {}
    return params;
  }

  function init() {
    var badge = document.getElementById('user-badge');
    var badgeName = document.getElementById('user-badge-name');
    var editPanel = document.getElementById('vars-edit-panel');
    var editBtn = document.getElementById('vars-edit-btn');
    var ui = document.getElementById('user-name-input');
    var save = document.getElementById('vars-save');
    var cancelEdit = document.getElementById('vars-cancel-edit');

    var params = getSearchParams();
    var qpDomain = params.get('CLUSTER_DOMAIN');
    var qpUser = params.get('USER_NAME');
    if (qpDomain) localStorage.setItem('CLUSTER_DOMAIN', qpDomain);
    if (qpUser) localStorage.setItem('USER_NAME', qpUser);

    var storedUser = localStorage.getItem('USER_NAME') || '';

    if (storedUser && badge && badgeName) {
      badgeName.textContent = storedUser;
      badge.style.display = 'inline';
      if (editBtn) editBtn.style.display = 'inline-block';
      if (editPanel) editPanel.style.display = 'none';
    } else {
      if (badge) badge.style.display = 'none';
      if (editBtn) editBtn.style.display = 'none';
      if (editPanel) editPanel.style.display = 'flex';
      if (ui) ui.value = '';
    }

    if (editBtn) editBtn.onclick = function() {
      badge.style.display = 'none';
      editBtn.style.display = 'none';
      editPanel.style.display = 'flex';
      if (ui) ui.value = storedUser;
      ui.focus();
    };

    if (cancelEdit) cancelEdit.onclick = function() {
      editPanel.style.display = 'none';
      if (storedUser) {
        badge.style.display = 'inline';
        editBtn.style.display = 'inline-block';
      }
    };

    if (save) save.onclick = function() {
      var u = (ui.value || '').trim();
      if (u) {
        localStorage.setItem('USER_NAME', u);
        location.reload();
      }
    };

    // Language switcher via Google Translate
    var currentLang = localStorage.getItem('SHOWROOM_LANG') || 'es';
    document.querySelectorAll('.lang-btn').forEach(function(btn) {
      var lang = btn.getAttribute('data-lang');
      if (lang === currentLang) {
        btn.style.background = '#EE0000';
        btn.style.color = '#fff';
        btn.style.border = 'none';
        btn.style.fontWeight = 'bold';
      } else {
        btn.style.background = '#3c3c3c';
        btn.style.color = '#ccc';
        btn.style.border = '1px solid #555';
        btn.style.fontWeight = 'normal';
      }
      btn.onclick = function() {
        localStorage.setItem('SHOWROOM_LANG', lang);
        if (lang === 'en') {
          translatePage('es', 'en');
        } else {
          undoTranslation();
        }
        document.querySelectorAll('.lang-btn').forEach(function(b) {
          if (b.getAttribute('data-lang') === lang) {
            b.style.background = '#EE0000'; b.style.color = '#fff'; b.style.border = 'none'; b.style.fontWeight = 'bold';
          } else {
            b.style.background = '#3c3c3c'; b.style.color = '#ccc'; b.style.border = '1px solid #555'; b.style.fontWeight = 'normal';
          }
        });
      };
    });

    if (currentLang === 'en') {
      setTimeout(function() { translatePage('es', 'en'); }, 800);
    }
  }

  var gtScriptLoaded = false;
  function translatePage(from, to) {
    if (!gtScriptLoaded) {
      window.googleTranslateElementInit = function() {
        new google.translate.TranslateElement({ pageLanguage: from, includedLanguages: to, autoDisplay: false }, 'google_translate_element');
        setTimeout(function() {
          var sel = document.querySelector('.goog-te-combo');
          if (sel) { sel.value = to; sel.dispatchEvent(new Event('change')); }
        }, 1000);
      };
      var s = document.createElement('script');
      s.src = 'https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
      document.body.appendChild(s);
      var d = document.createElement('div');
      d.id = 'google_translate_element';
      d.style.display = 'none';
      document.body.appendChild(d);
      gtScriptLoaded = true;
    } else {
      var sel = document.querySelector('.goog-te-combo');
      if (sel) { sel.value = to; sel.dispatchEvent(new Event('change')); }
    }
  }

  function undoTranslation() {
    var iframe = document.querySelector('.goog-te-banner-frame');
    if (iframe) {
      var btn = iframe.contentDocument.querySelector('.goog-close-link');
      if (btn) btn.click();
    }
    var sel = document.querySelector('.goog-te-combo');
    if (sel) { sel.value = ''; sel.dispatchEvent(new Event('change')); }
    setTimeout(function() { location.reload(); }, 300);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
</script>
